{
  "name": "jw-bench-v1",
  "version": "1.0.0",
  "description": "JW-Bench v1: Chinese Wire vs JSX Empirical Benchmark",
  "main": "benchmark/run.ts",
  "scripts": {
    "pilot": "npx ts-node benchmark/run.ts --phase pilot",
    "full": "npx ts-node benchmark/run.ts --phase full",
    "judge-cal": "npx ts-node benchmark/run.ts --phase judge-calibration",
    "validate-manifests": "npx ts-node scripts/validate-manifests.ts",
    "report": "echo 'Report auto-generated in runs/<date>/pilot-report.md after each run' && exit 0"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0",
    "json5": "^2.2.3",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "csv-stringify": "^6.4.6",
    "gpt-tokenizer": "^2.1.2",
    "dotenv": "^16.0.0",
    "openai": "^4.40.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0"
  }
}
